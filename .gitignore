.DS_Store
semantic.cache
bin/

*.tmp
*.tmp.obo
*.tmp.owl
*.tmp.json
*-relation-graph.tsv.gz
.template.db

.github/token.txt

/fix.owl
/fix.obo
/fix.json
/fix.db
/fix-base.*
/fix-basic.*
/fix-full.*
/fix-simple.*
/fix-simple-non-classified.*
/mappings/
/patterns/
/reports/
/subsets/

src/ontology/mirror
src/ontology/mirror/*
